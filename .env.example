# ============================================================================
# MealYummy Server - Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to Git!

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/meal-service

# PostgreSQL (Optional - if using relational DB)
DB_USERNAME=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=mealyummy_db
DB_LOCAL_PORT=5432

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
SERVER_PORT=8082

# ============================================================================
# JWT CONFIGURATION
# ============================================================================
# Generate secure secret: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here-change-this-in-production
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================================
# EMAIL CONFIGURATION (Brevo - Recommended for Production)
# ============================================================================
# Get your API key from: https://app.brevo.com/settings/keys/api
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-brevo-email@example.com
MAIL_PASSWORD=your-brevo-smtp-key

# Alternative: Gmail (Not recommended for production)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-gmail@gmail.com
# MAIL_PASSWORD=your-app-password

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
# Local Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false

# Production Redis (Upstash - recommended)
# Get from: https://console.upstash.com/
# REDIS_HOST=your-redis-host.upstash.io
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_SSL_ENABLED=true

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
FRONTEND_URL=http://localhost:5173
CLIENT_URL=http://localhost:5173

# ============================================================================
# GOOGLE OAUTH CONFIGURATION
# ============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================================
# OTP CONFIGURATION
# ============================================================================
OTP_EXPIRATION_MINUTES=5

# ============================================================================
# CLOUDINARY CONFIGURATION (Image Upload)
# ============================================================================
# Get from: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ============================================================================
# AI CONFIGURATION (Google Gemini)
# ============================================================================
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# AWS LOCATION SERVICE CONFIGURATION
# ============================================================================
# Get from: https://console.aws.amazon.com/iam/
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
AWS_LOCATION_PLACE_INDEX=MealYummyPlaceIndex

# ============================================================================
# MOMO PAYMENT CONFIGURATION
# ============================================================================
# Get from: https://business.momo.vn/
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
APP_URL=http://localhost:8082

# ============================================================================
# VNPAY CONFIGURATION (Optional)
# ============================================================================
VNPAY_TMN_CODE=your-vnpay-code
VNPAY_HASH_SECRET=your-vnpay-secret

# ============================================================================
# BREVO EMAIL API (Alternative method)
# ============================================================================
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-sender@example.com
